# =============================================================================
# auxd backend — environment configuration template
# -----------------------------------------------------------------------------
# Copy to `.env` for local development and fill in the secret values. The app
# validates every variable on startup via `auxd_api.settings.Settings` and will
# refuse to boot if anything is missing or malformed.
#
# Generate base64 keys quickly:
#   python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
# Deployment environment. One of: local | dev | staging | production
ENVIRONMENT=local

# Root logger level. One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Datastores
# -----------------------------------------------------------------------------
# MongoDB connection string including database name.
MONGODB_URI=mongodb://localhost:27017/auxd_dev

# Redis connection URL (sessions, queues, rate-limiting).
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Crypto secrets (REQUIRED — no defaults)
# -----------------------------------------------------------------------------
# Base64-encoded HMAC key for signing session cookies. Must decode to >= 32 bytes.
SESSION_HMAC_KEY=

# Base64-encoded AES-256 key for envelope-encrypting OAuth tokens at rest.
# Must decode to EXACTLY 32 bytes. See T017.
TOKEN_ENCRYPTION_KEY=

# Base64-encoded pepper used when hashing email-verification + password-reset
# tokens at rest (feature 002-auth-email-flows). Must decode to >= 32 bytes.
# Generate with:
#   python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Rotate independently of SESSION_HMAC_KEY — they protect different primitives.
AUTH_TOKEN_PEPPER=

# -----------------------------------------------------------------------------
# Catalog providers (optional)
# -----------------------------------------------------------------------------
# CR-001 (2026-05-22): Spotify integration removed. The MVP now ships with a
# Letterboxd-style manual catalog (MusicBrainz primary). Set DISCOGS_API_TOKEN
# below to enable the secondary Discogs fallback; leave blank to run
# MusicBrainz-only. See features/001-auxd-mvp/change-log.md for context.
DISCOGS_API_TOKEN=

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
# Sentry DSN. Leave blank to disable Sentry.
SENTRY_DSN=

# PostHog Cloud project API key (`phc_…`). Leave blank to disable PostHog.
POSTHOG_API_KEY=

# PostHog Cloud ingest host. US region: https://us.i.posthog.com (default).
# EU region: https://eu.i.posthog.com.
POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Email (optional) — Resend
# -----------------------------------------------------------------------------
# Resend API key (`re_…`). Leave blank to log emails locally instead of sending.
RESEND_API_KEY=
# Default 'from' address used by every Resend send (notifications, account
# emails, verification, password reset). RFC-5322 format. The mailbox's
# domain MUST be verified on Resend (resend.com/domains) — Resend rejects
# unverified senders with a 403. Falls back to
# "auxd <noreply@accounts.xiejoshua.com>" if unset; override per-environment.
RESEND_FROM_ADDRESS=

# -----------------------------------------------------------------------------
# Backups — Cloudflare R2 (S3-compatible)
# -----------------------------------------------------------------------------
# R2 API tokens (generate via Cloudflare → R2 → "API Tokens" → "Create API Token").
# Used by the nightly mongodump backup job (T010a).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# R2 S3-compatible endpoint URL. Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=

# R2 bucket name for backups. Default: auxd-backups.
R2_BUCKET_NAME=auxd-backups

# -----------------------------------------------------------------------------
# Web Push
# -----------------------------------------------------------------------------
# VAPID public key broadcast to browsers (safe to ship; mirrors apps/web/.env.example).
VAPID_PUBLIC_KEY=BDiJd1rvukJ-A2OmXOFR8n3ysqxSXrLkV8zUCdG48tybCANxC7nAKx2IdgsELt_mR4BT1onkqXDTV-ZicekBDvE

# VAPID private key. Required only when push delivery is enabled.
VAPID_PRIVATE_KEY=
