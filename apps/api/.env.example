# =============================================================================
# auxd backend — environment configuration template
# -----------------------------------------------------------------------------
# Copy to `.env` for local development and fill in the secret values. The app
# validates every variable on startup via `auxd_api.settings.Settings` and will
# refuse to boot if anything is missing or malformed.
#
# Generate base64 keys quickly:
#   python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
# Deployment environment. One of: local | dev | staging | production
ENVIRONMENT=local

# Root logger level. One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Datastores
# -----------------------------------------------------------------------------
# MongoDB connection string including database name.
MONGODB_URI=mongodb://localhost:27017/auxd_dev

# Redis connection URL (sessions, queues, rate-limiting).
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Crypto secrets (REQUIRED — no defaults)
# -----------------------------------------------------------------------------
# Base64-encoded HMAC key for signing session cookies. Must decode to >= 32 bytes.
SESSION_HMAC_KEY=

# Base64-encoded AES-256 key for envelope-encrypting OAuth tokens at rest.
# Must decode to EXACTLY 32 bytes. See T017.
TOKEN_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# Toggle Spotify OAuth + sync. When true, the Spotify creds below are required.
SPOTIFY_INTEGRATION_ENABLED=true

# -----------------------------------------------------------------------------
# Spotify (required when SPOTIFY_INTEGRATION_ENABLED=true)
# -----------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
# Sentry DSN. Leave blank to disable Sentry.
SENTRY_DSN=

# PostHog project API key. Leave blank to disable PostHog.
POSTHOG_API_KEY=

# PostHog ingest host. Override for self-hosted deployments.
POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
# Postmark server token. Leave blank to log emails locally instead of sending.
POSTMARK_API_KEY=

# -----------------------------------------------------------------------------
# Web Push
# -----------------------------------------------------------------------------
# VAPID public key broadcast to browsers (safe to ship; mirrors apps/web/.env.example).
VAPID_PUBLIC_KEY=BDiJd1rvukJ-A2OmXOFR8n3ysqxSXrLkV8zUCdG48tybCANxC7nAKx2IdgsELt_mR4BT1onkqXDTV-ZicekBDvE

# VAPID private key. Required only when push delivery is enabled.
VAPID_PRIVATE_KEY=
