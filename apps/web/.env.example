# =============================================================================
# auxd frontend — environment configuration template
# -----------------------------------------------------------------------------
# Copy to `.env.local` for local development (`.env.local` is gitignored).
# Anything prefixed `NEXT_PUBLIC_` is shipped to the browser bundle; everything
# else is server-only (read in Next.js server components / route handlers /
# middleware).
# =============================================================================

# -----------------------------------------------------------------------------
# Server-only env vars — read by Next.js at build/runtime, not exposed to browser
# -----------------------------------------------------------------------------

# Backend host for the Next.js rewrites proxy + server-side fetch.
# Browser API calls go through /api/v1/* on the frontend origin and Next.js
# rewrites them to API_BACKEND_URL/api/v1/* server-side. Same value is used
# by lib/api-server.ts for SSR fetches.
#   Local dev:   http://localhost:8000
#   Production:  https://api.xiejoshua.com
API_BACKEND_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Public (browser-readable) — NEXT_PUBLIC_ prefix is mandatory for client use
# -----------------------------------------------------------------------------

# VAPID public key for Web Push subscriptions. Safe to ship to the browser;
# its corresponding private key lives ONLY in the Fly secret VAPID_PRIVATE_KEY
# on the backend.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BDiJd1rvukJ-A2OmXOFR8n3ysqxSXrLkV8zUCdG48tybCANxC7nAKx2IdgsELt_mR4BT1onkqXDTV-ZicekBDvE

# Sentry DSN for the frontend project (separate from the backend DSN).
# Public by design — Sentry's DSN is intended to be embedded in client code;
# the secret part is the project's internal token, not the DSN.
# Wire this into a Next.js Sentry SDK in a later frontend task.
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Server-only (no NEXT_PUBLIC_ prefix) — read in route handlers / middleware
# -----------------------------------------------------------------------------
# (none required at this stage; future server-side auth / cookie signing may
# add SESSION_HMAC_KEY here, but the backend currently owns sessions.)
